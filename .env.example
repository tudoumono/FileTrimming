# ============================================================
# Document Processing Pipeline - 環境設定
# ============================================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# --- パス設定 ---
INPUT_DIR=C:\pipeline\input
WORK_DIR=C:\pipeline\work
OUTPUT_DIR=C:\pipeline\output

# --- LLM設定 ---
# プロバイダ: openai / ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama（ローカルLLM）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- 処理設定 ---
TOKEN_LIMIT=80000
QUALITY_THRESHOLD_HIGH=70
QUALITY_THRESHOLD_MEDIUM=40
LLM_TEMPERATURE=0.1

# --- 実行制御 ---
# 開始ステップ（1-6）
START_STEP=1
# 中間ファイルの扱い: overwrite / skip
FILE_CONFLICT_MODE=skip
# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 実行ログの出力先
LOG_FILE=C:\pipeline\work\logs\pipeline.log

# --- エンコーディング ---
DEFAULT_ENCODING=shift_jis
FALLBACK_ENCODINGS=utf-8,shift_jis,cp932,euc-jp
