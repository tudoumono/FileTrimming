# ドキュメント前処理パイプライン 環境設定
# このファイルを .env にコピーして値を設定してください。
# cp .env.example .env

# --- LLM バックエンド選択 ---
# "noop" = LLM なし (デフォルト), "openai" = OpenAI API, "local" = Ollama
# LLM_BACKEND=noop
# LLM_OBSERVATION_ONLY=true

# --- 並列実行設定 ---
# 文書数が多い場合は Step2 / Step3 から上げるのがおすすめです。
# Office COM を使う Step1 は安定性のため 1 を推奨します。
# NORMALIZE_WORKERS=1
# EXTRACT_WORKERS=4
# TRANSFORM_WORKERS=4

# --- OpenAI API (LLM_BACKEND=openai の場合に必要) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# --- Ollama (LLM_BACKEND=local の場合) ---
# API キー不要。Ollama が起動していれば接続可能。
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama-3-elyza-8b

# --- 共通接続オプション ---
# LLM_PROXY_URL=http://proxy.example:8080
# LLM_SKIP_SSL_VERIFY=false
